# ==============================================================================
# VIVA SALON PRODUCTION-GRADE GITIGNORE
# Cohesive rules for React (Vite) + Node.js (Express) + PostgreSQL (Prisma)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dependency Directories
# ------------------------------------------------------------------------------
node_modules/

# ------------------------------------------------------------------------------
# 2. Environment and Secret Files (Protect Credentials)
# ------------------------------------------------------------------------------
# Block all .env files and environment variants
.env
.env.*
backend/.env
frontend/.env
# Prevent env local backups
*.env
*.env.local

# Explicitly whitelist the example files to document required variables
!.env.example
!backend/.env.example
!frontend/.env.example

# ------------------------------------------------------------------------------
# 3. Build & Compilation Outputs
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
bin/
obj/
*.local

# ------------------------------------------------------------------------------
# 4. Testing & Coverage Reports
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ------------------------------------------------------------------------------
# 5. Logs & Diagnostics
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 6. Database (Prisma / PostgreSQL Local DB files)
# ------------------------------------------------------------------------------
# Local SQLite/Postgres dump and backup files if generated locally (but allow tracked SQL migrations)
*.db
*.db-journal
*.sqlite
*.sqlite-journal
*.dump
*.bak
prisma/dev.db
prisma/dev.db-journal

# ------------------------------------------------------------------------------
# 7. Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# 8. Editor and IDE Configuration Files
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swp

# ------------------------------------------------------------------------------
# 9. Runtime Uploads & Cache
# ------------------------------------------------------------------------------
# Generated runtime uploads folder (if uploads are created dynamically)
uploads/
backend/uploads/
.eslintcache
.parcel-cache
.cache/
tmp/
temp/