# ─── SERVER SETUP ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Use strong random strings in production
JWT_SECRET=your_jwt_signature_secret_here
ADMIN_REGISTRATION_SECRET=your_admin_registration_secret_here

# ─── DATABASE (Neon Serverless Postgres Connection) ───────────────────────────
# Connection pool URL
DATABASE_URL="postgresql://username:password@hostname-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct unpooled URL (required for some Prisma workflows)
DATABASE_URL_UNPOOLED="postgresql://username:password@hostname.region.aws.neon.tech/neondb?sslmode=require"

# ─── OWNER CONTACT ─────────────────────────────────────────────────────────────
OWNER_EMAIL=owner@vivasalon.com

# ─── NEON SERVICES ────────────────────────────────────────────────────────────
NEON_BRANCH=production
NEON_AUTH_BASE_URL=https://hostname.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://hostname.neonauth.region.aws.neon.tech/neondb/auth/.well-known/jwks.json

# ─── WHATSAPP / SMS via Twilio ─────────────────────────────────────────────────
# Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth Token from console
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio phone number/sender number
TWILIO_SMS_FROM_NUMBER=+14155238886
# Twilio WhatsApp sender (formatted as whatsapp:+number)
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# ─── MSG91 SMS Gateway (Optional) ─────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_msg91_template_id_here

# ─── Fast2SMS Gateway (Optional) ──────────────────────────────────────────────
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ─── EMAIL (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
